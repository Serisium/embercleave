summary: Boot the embercleave bootc image in a VM and verify it comes up healthy.
description: |
  Builds a qcow2 from the OCI image via bootc-image-builder, boots it
  under libvirt with virtual.testcloud, and runs every test under
  /tests/boot inside the booted system.

  TMT_BOOTC_IMAGE selects the OCI image to provision from. Defaults to
  localhost/embercleave-bootc:test.

provision:
  how: bootc
  container-image: $@TMT_BOOTC_IMAGE

discover:
  how: fmf
  filter: tier:smoke

execute:
  how: tmt
