# Runtime container for worker pis. Used only by embercleave-worker@.container
# (one instance per worker). The manager runs on the host directly under
# swarm's user-mode systemd — see image/systemd/embercleave-mgr.service —
# so no manager packages are installed here.
#
# Per arch.md §4.2 the worker package is a pi extension. Entry is `pi`;
# extension loading and bus connection come from the EnvironmentFile the
# Quadlet mounts at %h/.config/embercleave/instances/%i.env.

FROM docker.io/library/node:20-slim

RUN apt-get update \
 && apt-get install -y --no-install-recommends git ca-certificates tini \
 && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home --shell /bin/bash worker

USER worker
WORKDIR /home/worker

RUN npm install -g \
      @mariozechner/pi-coding-agent \
      @serisium/embercleave-protocol \
      @serisium/embercleave-worker

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["pi"]
