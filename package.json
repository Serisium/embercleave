{
  "name": "embercleave",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Swarm orchestration on a fedora-bootc host. See arch.md.",
  "engines": {
    "node": ">=20.18.1"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "pnpm -r run test",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "build:image": "image/scripts/build-bootc.sh",
    "lint:image": "image/scripts/lint.sh",
    "test:image:structure": "image/scripts/test-structure.sh",
    "test:image:boot": "image/scripts/test-boot.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "2.31.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
